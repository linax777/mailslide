# Write File Plugin Configuration
# Action: Write email data to JSON file (one file per email)

enabled: true

# Output directory for JSON files (absolute or relative path)
# Can use environment variables like ${HOME}/output
output_dir: "output"

# Filename format (use {subject} and {timestamp} placeholders)
filename_format: "{subject}_{timestamp}"

# Fields to include in JSON output
include_fields:
  - subject
  - sender
  - received
  - body
  - tables
  # Add other fields as needed: to, cc, categories, etc.

# Note: This plugin does not require LLM response and can run independently
# Place it first in the plugins list to save email data before any modifications

_ui:
  schema_version: 1
  title: "Plugin: write_file"
  buttons:
    - id: validate
      label: "Validate"
      action: validate
    - id: save
      label: "Save"
      action: save
      variant: success
  fields:
    enabled:
      type: bool
      label: "Enabled"
      required: true
    output_dir:
      type: path
      label: "Output directory"
      required: true
      placeholder: "output"
    filename_format:
      type: str
      label: "Filename format"
      required: true
      help: "Available placeholders: {subject}, {timestamp}"
    include_fields:
      type: list[str]
      label: "Output fields"
      required: true
      default:
        - subject
        - sender
        - received
        - body
        - tables
  validation_rules:
    - id: required_placeholders
      level: warning
      message: "filename_format should include {timestamp} to avoid overwrites"
      check: "contains(config.filename_format,'{timestamp}')"
    - id: include_fields_not_empty
      level: error
      message: "include_fields cannot be empty"
      check: "count(config.include_fields) > 0"

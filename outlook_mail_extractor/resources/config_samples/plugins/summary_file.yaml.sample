# Summary File Plugin Configuration
# Action: Summarize email content and append result rows to CSV

enabled: true

# Default system prompt for this plugin
# The JSON format will be automatically appended to this prompt
system_prompt: |
  You are an email summarization assistant. Produce a concise summary based on the email content.

  Respond with JSON only. Do not include extra text, explanations, or markdown.

# Prompt profiles: define multiple system prompts for different use cases
# Each job can select which profile to use via plugin_prompt_profiles in config.yaml
# Default profile used when job doesn't specify one
default_prompt_profile: general_v1

prompt_profiles:
  general_v1:
    version: 1
    description: "General email summary"
    system_prompt: |
      You are an email summarization assistant. Produce a concise summary based on the email content.

      Respond with JSON only. Do not include extra text, explanations, or markdown.

# JSON response format (automatically appended to system prompt)
response_json_format:
  has_summary: '{"action": "summary", "summary": "2-5 sentence key summary", "priority": "high"}'

# Output CSV file (single file, append mode)
output_file: "output/email_summaries.csv"

# CSV schema is fixed in code:
# email_subject, email_sender, email_received, summary, priority, logged_at
# priority is optional; recommended values: high, medium, low

# Response format (json, text)
response_format: "json"

_ui:
  schema_version: 1
  title: "Plugin: summary_file"
  buttons:
    - id: validate
      label: "Validate"
      action: validate
    - id: save
      label: "Save"
      action: save
      variant: success
  fields:
    enabled:
      type: bool
      label: "Enabled"
      required: true
    system_prompt:
      type: textarea
      label: "System Prompt (Default)"
      required: false
      rows: 8
    default_prompt_profile:
      type: str
      label: "Default Prompt Profile"
      required: false
      placeholder: "general_v1"
    prompt_profiles:
      type: yaml
      label: "Prompt Profiles"
      required: false
      rows: 15
      placeholder: "general_v1:\n  version: 1\n  system_prompt: |"
    output_file:
      type: path
      label: "CSV file"
      required: true
      placeholder: "output/email_summaries.csv"
    response_format:
      type: select
      label: "Response Format"
      required: true
      default: json
      options:
        - json
        - text
  validation_rules:
    - id: output_file_csv
      level: warning
      message: "output_file should use a .csv extension"
      check: "ends_with(lower(config.output_file),'.csv')"
    - id: response_format_enum
      level: error
      message: "response_format supports only json/text"
      check: "in(config.response_format,['json','text'])"

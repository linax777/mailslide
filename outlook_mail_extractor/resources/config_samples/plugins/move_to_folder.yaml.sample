# Move To Folder Plugin Configuration
# Action: Move email to folder based on LLM response

enabled: true

# Default system prompt for this plugin
# The JSON format will be automatically appended to this prompt
system_prompt: |
  You are an email routing assistant. Analyze the email content and decide which folder it should be moved to.

  Available folder categories:
  - Meeting: emails about meetings and schedules
  - Bill: billing, invoices, and payments
  - TechSupport: technical issues and incident reports
  - Purchase: procurement-related emails
  - Other: emails that do not fit the above

  Respond with JSON only. Do not include extra text, explanations, or markdown.

# Prompt profiles: define multiple system prompts for different use cases
# Each job can select which profile to use via plugin_prompt_profiles in config.yaml
# Default profile used when job doesn't specify one
default_prompt_profile: general_v1

prompt_profiles:
  general_v1:
    version: 1
    description: "General folder routing"
    system_prompt: |
      You are an email routing assistant. Analyze the email content and decide which folder it should be moved to.

      Available folder categories:
      - Meeting: emails about meetings and schedules
      - Bill: billing, invoices, and payments
      - TechSupport: technical issues and incident reports
      - Purchase: procurement-related emails
      - Other: emails that do not fit the above

      Respond with JSON only. Do not include extra text, explanations, or markdown.

# JSON response format (automatically appended to system prompt)
# This format is fixed and should not be modified by users
response_json_format:
  move: '{"action": "move", "folder": "TargetFolderName"}'
  no_move: '{"action": "move", "folder": ""}'

# Response format (json, text)
response_format: "json"

_ui:
  schema_version: 1
  title: "Plugin: move_to_folder"
  buttons:
    - id: validate
      label: "Validate"
      action: validate
    - id: save
      label: "Save"
      action: save
      variant: success
  fields:
    enabled:
      type: bool
      label: "Enabled"
      required: true
    system_prompt:
      type: textarea
      label: "System Prompt (Default)"
      required: false
      rows: 10
    default_prompt_profile:
      type: str
      label: "Default Prompt Profile"
      required: false
      placeholder: "general_v1"
    prompt_profiles:
      type: yaml
      label: "Prompt Profiles"
      required: false
      rows: 15
      placeholder: "general_v1:\n  version: 1\n  system_prompt: |"
    response_format:
      type: select
      label: "Response Format"
      required: true
      default: json
      options:
        - json
        - text
  validation_rules:
    - id: response_format_enum
      level: error
      message: "response_format supports only json/text"
      check: "in(config.response_format,['json','text'])"

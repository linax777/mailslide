# Create Appointment Plugin Configuration
# Action: Create calendar appointment from email content based on LLM response

enabled: true

# Default system prompt for this plugin
# The JSON format will be automatically appended to this prompt
system_prompt: |
  You are a calendar assistant. Analyze the email content and determine whether it includes appointment, meeting, or schedule information.

  Respond with JSON only. Do not include extra text, explanations, or markdown.

# Prompt profiles: define multiple system prompts for different use cases
# Each job can select which profile to use via plugin_prompt_profiles in config.yaml
# Default profile used when job doesn't specify one
default_prompt_profile: general_v1

prompt_profiles:
  general_v1:
    version: 1
    description: "General meeting and schedule detection"
    system_prompt: |
      You are a calendar assistant. Analyze the email content and determine whether it includes appointment, meeting, or schedule information.

      Respond with JSON only. Do not include extra text, explanations, or markdown.

# JSON response format (automatically appended to system prompt)
# This format is fixed and should not be modified by users
response_json_format:
  create_true: '{"action": "appointment", "create": true, "subject": "Meeting subject", "start": "2024-01-15T14:00:00", "end": "2024-01-15T15:00:00", "location": "Meeting room or online link", "body": "Additional notes"}'
  create_false: '{"action": "appointment", "create": false}'

# Recipients to add to appointments (configured here, not by LLM)
# Example: ["john@example.com", "jane@example.com"]
recipients: []

# Response format (json, text)
response_format: "json"

_ui:
  schema_version: 1
  title: "Plugin: create_appointment"
  buttons:
    - id: validate
      label: "Validate"
      action: validate
    - id: save
      label: "Save"
      action: save
      variant: success
  fields:
    enabled:
      type: bool
      label: "Enabled"
      required: true
    system_prompt:
      type: textarea
      label: "System Prompt (Default)"
      required: false
      rows: 8
    default_prompt_profile:
      type: str
      label: "Default Prompt Profile"
      required: false
      placeholder: "general_v1"
    prompt_profiles:
      type: yaml
      label: "Prompt Profiles"
      required: false
      rows: 15
      placeholder: "general_v1:\n  version: 1\n  system_prompt: |"
    recipients:
      type: list[str]
      label: "Recipients"
      required: false
      placeholder: "name@example.com"
    response_format:
      type: select
      label: "Response Format"
      required: true
      default: json
      options:
        - json
        - text
  validation_rules:
    - id: recipients_email_like
      level: warning
      message: "recipients should look like valid email addresses"
      check: "all(config.recipients, is_email_like)"
    - id: response_format_enum
      level: error
      message: "response_format supports only json/text"
      check: "in(config.response_format,['json','text'])"

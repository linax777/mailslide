# Event Table Plugin Configuration
# Action: Extract appointment-like events from emails and append to Excel

enabled: true

# Default system prompt for this plugin
# The JSON format will be automatically appended to this prompt
system_prompt: |
  You are a calendar assistant. Analyze the email content and determine whether it includes appointment, meeting, or schedule information.

  Respond with JSON only. Do not include extra text, explanations, or markdown.

# Prompt profiles: define multiple system prompts for different use cases
# Each job can select which profile to use via plugin_prompt_profiles in config.yaml
# Default profile used when job doesn't specify one
default_prompt_profile: general_v1

prompt_profiles:
  general_v1:
    version: 1
    description: "General meeting and schedule event extraction"
    system_prompt: |
      You are a calendar assistant. Analyze the email content and determine whether it includes appointment, meeting, or schedule information.

      Respond with JSON only. Do not include extra text, explanations, or markdown.

# JSON response format (automatically appended to system prompt)
response_json_format:
  create_true: '{"action": "appointment", "create": true, "subject": "Meeting subject", "start": "2024-01-15T14:00:00", "end": "2024-01-15T15:00:00", "location": "Meeting room or online link", "body": "Additional notes"}'
  create_false: '{"action": "appointment", "create": false}'

# Output Excel file (single file, append mode)
output_file: "output/events.xlsx"

# Excel schema is fixed in code:
# email_subject, email_sender, email_received, email_entry_id,
# outlook_open_command, event_subject, start, end, location, body, logged_at

# Response format (json, text)
response_format: "json"

# Whether outlook_open_command should also require sender match
open_command_match_sender: false

_ui:
  schema_version: 1
  title: "Plugin: event_table"
  buttons:
    - id: validate
      label: "Validate"
      action: validate
    - id: save
      label: "Save"
      action: save
      variant: success
  fields:
    enabled:
      type: bool
      label: "Enabled"
      required: true
    system_prompt:
      type: textarea
      label: "System Prompt (Default)"
      required: false
      rows: 8
    default_prompt_profile:
      type: str
      label: "Default Prompt Profile"
      required: false
      placeholder: "general_v1"
    prompt_profiles:
      type: yaml
      label: "Prompt Profiles"
      required: false
      rows: 15
      placeholder: "general_v1:\n  version: 1\n  system_prompt: |"
    output_file:
      type: path
      label: "Excel file"
      required: true
      placeholder: "output/events.xlsx"
    response_format:
      type: select
      label: "Response Format"
      required: true
      default: json
      options:
        - json
        - text
    open_command_match_sender:
      type: bool
      label: "Match sender in open command"
      required: false
      default: false
  validation_rules:
    - id: output_file_xlsx
      level: warning
      message: "output_file should use a .xlsx extension"
      check: "ends_with(lower(config.output_file),'.xlsx')"
    - id: response_format_enum
      level: error
      message: "response_format supports only json/text"
      check: "in(config.response_format,['json','text'])"

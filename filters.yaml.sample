# Email Filter Conditions
# Define filters here, reference by name in config.yaml jobs

# Example filter: Meeting-related emails
meeting_filter:
  from_contains: "@company.com"
  subject_contains: ["meeting", "calendar", "invite", "жңғиӯ°"]
  is_unread: true

# Example filter: Bill/Invoice emails
bill_filter:
  from_contains: ["billing@service.com", "invoice@vendor.com"]
  subject_contains: ["invoice", "bill", "payment", "еёіе–®", "зҷјзҘЁ"]

# Example filter: Urgent emails
urgent_filter:
  subject_contains: ["urgent", "з·ҠжҖҘ", "ASAP"]
  importance: high

# Default filter - no conditions, just limit
default:
  limit: 10

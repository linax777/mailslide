# Main configuration - Jobs basic info
# Rename to config.yaml to use
#
# Job fields:
#   - name: Job name (display only)
#   - enable: true/false - whether to execute this job (default: true)
#   - account: Outlook account email
#   - source: Source folder path (e.g., "收件匣/microsoft")
#   - destination: Destination folder for auto-move (optional)
#   - manual_review_destination: Destination for LLM non-action/failed mails (optional)
#   - limit: Max emails to process per job
#   - body_max_length: Max cleaned body length for LLM/input (optional)
#   - llm_mode: LLM dispatch mode (optional, default: per_plugin)
#   - ui_language: UI language (optional, zh-TW/en-US, default: zh-TW)
#   - terminal_title: Terminal tab/window title (optional, default: Mailslide)
#   - plugin_modules: Extra Python modules to import for plugin discovery (optional)
#   - plugins: List of plugins to run (LLM analysis)
#   - batch_flush_enabled: Flush writable plugin outputs at job end (default: true)
#   - plugin_prompt_profiles: Per-job prompt profile mapping (optional)
#
# IMPORTANT:
#   - Use "destination" for simple auto-move (no LLM needed)
#   - Use "plugins" for LLM analysis (add_category, create_appointment, etc.)
#   - DO NOT use "move_to_folder" plugin together with "destination"
#     (they both move emails and will conflict)
#   - When manual_review_destination is set, mails without LLM action
#     (skipped/failed/retriable_failed) will move there for manual review

config_version: 2
body_max_length: 2500
llm_mode: per_plugin
ui_language: zh-TW
# terminal_title: "Mailslide"
# Optional dynamic plugin discovery modules
# plugin_modules:
#   - custom_plugins.my_plugin_module

jobs:
  - name: "處理microsoft郵件"
    enable: true
    account: "your@email.com"
    source: "收件匣/microsoft"
    destination: "收件匣/microsoft/processed"
    # manual_review_destination: "收件匣/microsoft/manual_review"
    limit: 10
    # Optional per-job override (falls back to top-level body_max_length)
    # body_max_length: 3000
    # Optional per-job override (per_plugin | share_deprecated)
    # llm_mode: per_plugin
    # Optional per-job override (default: true)
    # batch_flush_enabled: true
    plugins:
      - add_category

  - name: "處理帳單"
    enable: false  # This job will be skipped
    account: "your@email.com"
    source: "收件匣/bills"
    destination: "收件匣/bills/processed"
    limit: 5
    batch_flush_enabled: true
    plugins:
      - add_category
      - create_appointment
    # Specify prompt profile per plugin for this job only
    plugin_prompt_profiles:
      add_category: invoice_v1
      create_appointment: general_v1

# UI schema metadata for future TUI form builder.
# Reserved key prefix: _ui / _meta (ignored by runtime execution logic).
_ui:
  schema_version: 1
  title: "主設定"
  description: "設定 jobs、資料夾、plugins 與處理上限"
  buttons:
    - id: add_job
      label: "新增 Job"
      label_key: "ui.main.button.add_job"
      action: add_list_item
      target: jobs
      variant: primary
    - id: edit_job
      label: "修改 Job"
      label_key: "ui.main.button.edit_job"
      action: edit_list_item
      target: jobs
      variant: default
    - id: remove_job
      label: "刪除 Job"
      label_key: "ui.main.button.remove_job"
      action: remove_list_item
      target: jobs
      variant: warning
    - id: validate
      label: "驗證設定"
      label_key: "ui.main.button.validate"
      action: validate
      variant: default
    - id: reload
      label: "重新載入"
      label_key: "ui.main.button.reload"
      action: reload
      variant: default
    - id: save
      label: "儲存"
      label_key: "ui.main.button.save"
      action: save
      variant: success
    - id: reset
      label: "回復範本"
      label_key: "ui.main.button.reset"
      action: reset_from_sample
      variant: error
      confirm: true
  fields:
    body_max_length:
      type: int
      label: "內文長度上限"
      required: false
      min: 1
      help: "全域預設值；可被 job.body_max_length 覆蓋"
    llm_mode:
      type: select
      label: "LLM 模式"
      required: false
      default: per_plugin
      options:
        - per_plugin
        - share_deprecated
      help: "per_plugin: 每個 plugin 各自呼叫 LLM；share_deprecated: 共用一次回覆（舊模式）"
    plugin_modules:
      type: textarea
      label: "Plugin 模組載入清單"
      required: false
      rows: 3
      placeholder: "custom_plugins.my_plugin_module"
      help: "每行一個 Python 模組路徑，啟動時會動態 import 以註冊額外 plugins"
    jobs:
      type: list
      label: "工作清單"
      min_items: 1
      item_label_field: name
      item_fields:
        name:
          type: str
          label: "工作名稱"
          required: true
          max_length: 100
        enable:
          type: bool
          label: "啟用"
          required: false
          default: true
        account:
          type: str
          label: "Outlook 帳號"
          required: true
          placeholder: "your@email.com"
        source:
          type: str
          label: "來源資料夾"
          required: true
          placeholder: "收件匣/分類"
        destination:
          type: str
          label: "目標資料夾"
          required: false
          placeholder: "收件匣/分類/processed"
        manual_review_destination:
          type: str
          label: "人工判斷資料夾"
          required: false
          placeholder: "收件匣/分類/manual_review"
        limit:
          type: int
          label: "處理上限"
          required: false
          default: 10
          min: 1
          max: 1000
        body_max_length:
          type: int
          label: "內文長度上限（Job 覆蓋）"
          required: false
          min: 1
        llm_mode:
          type: select
          label: "LLM 模式（Job 覆蓋）"
          required: false
          options:
            - per_plugin
            - share_deprecated
        batch_flush_enabled:
          type: bool
          label: "批次寫入"
          required: false
          default: true
          help: "啟用後，event_table/summary_file 會在 job 結束時一次寫入"
        plugins:
          type: multiselect
          label: "Plugins"
          required: false
          options:
            - add_category
            - create_appointment
            - move_to_folder
            - write_file
            - event_table
            - summary_file
        plugin_prompt_profiles:
          type: textarea
          label: "Plugin Prompt Profiles (YAML)"
          required: false
          rows: 3
          placeholder: "add_category: invoice_v1"
  validation_rules:
    - id: required_name_account_source
      level: error
      message: "每個 Job 必須包含 name/account/source"
      message_key: "ui.main.rule.required_name_account_source"
      check: "job.name && job.account && job.source"
    - id: limit_positive
      level: error
      message: "limit 必須是正整數"
      message_key: "ui.main.rule.limit_positive"
      check: "!job.limit || (is_int(job.limit) && job.limit > 0)"
    - id: body_max_length_positive
      level: error
      message: "body_max_length 必須是正整數"
      message_key: "ui.main.rule.body_max_length_positive"
      check: "!job.body_max_length || (is_int(job.body_max_length) && job.body_max_length > 0)"
    - id: llm_mode_enum
      level: error
      message: "llm_mode 僅支援 per_plugin/share_deprecated"
      message_key: "ui.main.rule.llm_mode_enum"
      check: "!has_text(config.llm_mode) || in(config.llm_mode,['per_plugin','share_deprecated'])"
    - id: job_llm_mode_enum
      level: error
      message: "job.llm_mode 僅支援 per_plugin/share_deprecated"
      message_key: "ui.main.rule.job_llm_mode_enum"
      check: "!has_text(job.llm_mode) || in(job.llm_mode,['per_plugin','share_deprecated'])"
    - id: destination_move_conflict
      level: error
      message: "使用 move_to_folder 時，請不要同時設定 destination"
      message_key: "ui.main.rule.destination_move_conflict"
      check: "!(includes(job.plugins,'move_to_folder') && has_text(job.destination))"
    - id: unique_job_name
      level: warning
      message: "建議 Job 名稱不要重複，方便追蹤"
      message_key: "ui.main.rule.unique_job_name"
      check: "unique(config.jobs[].name)"
    - id: at_least_one_enabled
      level: warning
      message: "目前沒有啟用的 Job"
      message_key: "ui.main.rule.at_least_one_enabled"
      check: "count(config.jobs[?enable!=false]) > 0"

# Create Appointment Plugin Configuration
# Action: Create calendar appointment from email content based on LLM response

enabled: true

# Default system prompt for this plugin
# LLM should respond with JSON for appointment details
system_prompt: |
  你是一個日曆助手。分析以下郵件內容，判斷是否包含預約、會議或行程資訊。
  
  如果需要建立約會，回覆以下 JSON 格式：
  {
    "action": "appointment",
    "create": true,
    "subject": "約會主題",
    "start": "2024-01-15T14:00:00",  # ISO 格式時間
    "end": "2024-01-15T15:00:00",
    "location": "會議室或線上連結",
    "body": "額外備註"
  }
  
  如果不需要建立約會：
  {"action": "appointment", "create": false}

# Response format (json, text)
response_format: "json"

# Event Table Plugin Configuration
# Action: Extract appointment-like events from emails and append to CSV

enabled: true

# Default system prompt for this plugin
# The JSON format will be automatically appended to this prompt
system_prompt: |
  你是一個日曆助手。分析以下郵件內容，判斷是否包含預約、會議或行程資訊。

  回覆時只輸出 JSON，不要有任何其他文字、解釋或 markdown 格式。

# JSON response format (automatically appended to system prompt)
response_json_format:
  create_true: '{"action": "appointment", "create": true, "subject": "約會主題", "start": "2024-01-15T14:00:00", "end": "2024-01-15T15:00:00", "location": "會議室或線上連結", "body": "額外備註"}'
  create_false: '{"action": "appointment", "create": false}'

# Output CSV file (single file, append mode)
output_file: "output/events.csv"

# CSV schema is fixed in code:
# email_subject, email_sender, email_received, event_subject,
# start, end, location, body, logged_at

# Response format (json, text)
response_format: "json"

_ui:
  schema_version: 1
  title: "Plugin: event_table"
  buttons:
    - id: validate
      label: "驗證"
      action: validate
    - id: save
      label: "儲存"
      action: save
      variant: success
  fields:
    enabled:
      type: bool
      label: "啟用"
      required: true
    system_prompt:
      type: textarea
      label: "System Prompt"
      required: false
      rows: 8
    output_file:
      type: path
      label: "CSV 檔案"
      required: true
      placeholder: "output/events.csv"
    response_format:
      type: select
      label: "Response Format"
      required: true
      default: json
      options:
        - json
        - text
  validation_rules:
    - id: output_file_csv
      level: warning
      message: "建議 output_file 使用 .csv 副檔名"
      check: "ends_with(lower(config.output_file),'.csv')"
    - id: response_format_enum
      level: error
      message: "response_format 僅支援 json/text"
      check: "in(config.response_format,['json','text'])"

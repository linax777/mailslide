# Main configuration - Jobs basic info
# Rename to config.yaml to use

jobs:
  - name: "處理會議郵件"
    account: "your@email.com"
    filter: "meeting_filter"    # Reference to filters.yaml
    plugins: ["move_to_folder", "add_category"]
    limit: 10

  - name: "處理帳單"
    account: "your@email.com"
    filter: "bill_filter"
    plugins: ["add_category"]
    limit: 5
